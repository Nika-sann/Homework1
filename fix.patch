+        height: 626.63px;
+    }
+
+    .games-mini__form {
+        display: flex;
+        flex-direction: column;
+        justify-content: flex-start;
+        align-items: flex-start;
+        gap: 9px;
+        padding: 29.04px 29.04px 32.67px 29.04px;
+    }
+
+    .games-mini__form-1 {
+        width: 284.93px;
+        height: 182px;
+    }
+
+    .games-mini__form-2 {
+        width: 284.93px;
+        height: 221px;
+    }
+
+    .games-mini__form-3 {
+        width: 284.93px;
+        height: 221px;
+    }
+
+    .games-mini__form-4 {
+        width: 284.93px;
+        height: 182px;
+    }
+
+    .games-mini__form-5 {
+        width: 284.93px;
+        height: 260px;
+    }
+
+    .games-mini__form-6 {
+        width: 284.93px;
+        height: 280px;
+    }
+
+    .games-mini__text {
+        /* Угадай число */
+        width: 284.93px;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        color: rgba(32, 32, 39, 1);
+        font-family: Montserrat;
+        font-style: Bold;
+        font-size: 32px;
+        font-weight: 700;
+        line-height: 39px;
+        letter-spacing: 0px;
+        text-align: left;
+    }
+
+    .games-mini__text-1 {
+        width: 284.93px;
+        height: 39px;
+    }
+
+    .games-mini__text-2 {
+        width: 284.93px;
+        height: 78px;
+    }
+
+    .games-mini__text-3 {
+        width: 284.93px;
+        height: 78px;
+    }
+
+    .games-mini__text-4 {
+        width: 284.93px;
+        height: 39px;
+    }
+
+    .games-mini__text-5 {
+        width: 284.93px;
+        height: 117px;
+    }
+
+    .games-mini__text-6 {
+        width: 284.93px;
+        height: 117px;
+    }
+
+    .games-mini__paragraf {
+        /* Попробуй угадать случайное число от 1 до 100. */
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        color: rgba(0, 0, 0, 1);
+        font-family: Montserrat;
+        font-style: Regular;
+        font-size: 16px;
+        font-weight: 400;
+        line-height: 20px;
+        letter-spacing: 0px;
+        text-align: left;
+    }
+
+    .games-mini__paragraf-1 {
+        width: 249px;
+        height: 40px;
+    }
+
+    .games-mini__paragraf-2 {
+        width: 233px;
+        height: 40px;
+    }
+    .games-mini__paragraf-3 {
+        width: 275px;
+        height: 40px;
+    }
+    .games-mini__paragraf-4 {
+        width: 285px;
+        height: 40px;
+    }
+    .games-mini__paragraf-5 {
+        width: 285px;
+        height: 40px;
+    }
+    .games-mini__paragraf-6 {
+        width: 285px;
+        height: 60px;
+    }
+
+    .games-mini__tup {
+        width: 285px;
+        height: 55px;
+        display: flex;
+        flex-direction: row;
+        justify-content: center;
+        align-items: center;
+        gap: 10px;
+        font-family: Montserrat;
+        font-weight: 600;
+        font-size: 16px;
+        line-height: 142%;
+        text-align: center;
+    }
+
+    .games-mini__item {
+        width: 343px;
+        height: 284.93px;
+    }
+
+    .footer {
+        height: 100px;
+        margin-top: 10px;
+}
+
+    .footer-text {
+        /* Все права защищены. */
+        font-size: 16px;
+        font-weight: 600;
+        line-height: 20px;
     }
 }
