+        height: 700px;
+        padding-top: 0px;
+        display: flex;
+        flex-direction: column;}
+
+
+    .header {
+        width: 343px;
+        display: flex;
+        flex-direction: column;
+        justify-content: center;
+        align-items: center;
+    }
+
+
+    .top__content {
+        width: 296px;
+        height: 280px;
+        display: flex;
+        flex-direction: column;
+        justify-content: center;
+        align-items: center;
+        margin-top: 64px;
+    }
+
+    .top__content-title {
+        /* Добро пожаловать на мой сайт мини-игр */
+        width: 262px;
+        height: 196px;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        color: rgba(32, 32, 39, 1);
+        font-family: Montserrat;
+        font-style: Bold;
+        font-size: 40px;
+        font-weight: 700;
+        line-height: 49px;
+        letter-spacing: 0px;
+        text-align: center;
+        padding-top: 264px;
+    }
+
+    .top__content-title-text {
+        /* Тебе предстоит пройти несколько увлекательных игр. Если готов, нажимай «Поехали!» и приступай. */
+        width: 296px;
+        height: 60px;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        color: rgba(32, 32, 39, 1);
+        font-family: Montserrat;
+        font-size: 16px;
+        font-weight: undefined;
+        line-height: 19px;
+        letter-spacing: 0px;
+        text-align: center;
+    }
+
+    .top__tup {
+        margin-top: 48px;
+        background: rgb(32, 32, 39, 1);
+        border: 1px solid rgb(32, 32, 39, 1);;
+        box-sizing: border-box;
+        border-radius: 60px;
+        width: 285px;
+        height: 55px;
+        font-size: 16px;
+        line-height: 141.69%;
+        color: rgb(255, 255, 255);
+        font-family: Montserrat;
+        padding: 16px 16px 24px 24px;
+    }
+
+    .games-section {
+        display: none;
+    }
+
+
+
+    .games-mini__text-top {
+        /* Мини-игры */
+        width: 250px;
+        height: 49px;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        color: rgba(255, 255, 255, 1);
+        font-family: Montserrat;
+        font-style: Bold;
+        font-size: 40px;
+        font-weight: 700;
+        line-height: 49px;
+        letter-spacing: 0px;
+        text-align: left;
+        padding-left: 18px;
+    }
+    .games-mini__play {
+          margin-top: 48px;
+    }
+
+    .games-mini__card {
+        width: 343px; 
+        height: 100%; 
+        display: flex;
+        gap: 24px;
+    }
+
+    .games-mini__blok-right, .games-mini__blok-left {
+        display: flex;
+        flex-direction: column-reverse;
+        justify-content: flex-start;
+        align-items: flex-start;
+    }
+
+    .games-mini__blok-1 {
+        width: 343px;
+        height: 528.63px;
+    }
+
+    .games-mini__blok-2 {
+        width: 343px;
+        height: 567.63px;
+    }
+
+    .games-mini__blok-3 {
+        width: 343px;
+        height: 567.63px;
+    }
+
