@@ -1,6 +1,326 @@
 @media (max-width: 764px) {
+    
     .center {
-        padding-left: 16px;
         padding-right: 16px;
+        padding-left: 16px;
+    }
+
+    body {
+        width: 376px;
+    }
+
+    .top {
+        text-align: center;
+        background-image:
+        url(images/zvezdaminitop.png),
+        url(images/Starmini2.png),
+        url(images/Star3mini.png),
+        url(images/Starmini4.png),
+        url(images/Starmini5.png),
+        url(images/polosamini.png);
